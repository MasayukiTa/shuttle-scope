[bandit]
# Skip note-tier rules FP for this prototype.
# Rationale: docs/validation/security-code-scanning-2026-04-23.md
#   B101  assert in tests / dev-only assertions
#   B110  try/except/pass in best-effort cleanup paths
#   B311  random in test data generators and seed scripts (not crypto)
#   B603  subprocess w/o shell=True, operator-controlled argv
#   B404  subprocess import audited
#   B607  partial exec path for maintenance scripts
#   B105  sample/test string literals flagged as hardcoded passwords
#   B112  try/except/continue in best-effort loops
skips: B101,B110,B311,B603,B404,B607,B105,B112
exclude: /shuttlescope/backend/tests,/shuttlescope/backend/.venv,/shuttlescope/node_modules,/shuttlescope/out,/shuttlescope/scripts/security_ci
